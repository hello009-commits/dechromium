 namespace {
 
+// Aspect: parse hex-based "HEX=value" param string into a map.
+// Format: "0D33=16384,0D3D=32767x32767,846E=1-1,..."
+// GLenum keys are hex (no 0x prefix), values are int, WxH, or min-max.
+using AspectParamMap = std::unordered_map<GLenum, std::string>;
+
+const AspectParamMap& GetAspectWebglParams() {
+  static const base::NoDestructor<AspectParamMap> params([]() -> AspectParamMap {
+    AspectParamMap m;
+    const auto& cmd = *base::CommandLine::ForCurrentProcess();
+    if (!cmd.HasSwitch(blink::switches::kAspectWebglParams))
+      return m;
+    std::string raw = cmd.GetSwitchValueASCII(blink::switches::kAspectWebglParams);
+    for (const auto& pair : base::SplitStringPiece(
+             raw, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+      size_t eq = pair.find('=');
+      if (eq == std::string_view::npos)
+        continue;
+      uint32_t hex_val = 0;
+      if (!base::HexStringToUInt(pair.substr(0, eq), &hex_val))
+        continue;
+      m[static_cast<GLenum>(hex_val)] = std::string(pair.substr(eq + 1));
+    }
+    return m;
+  }());
+  return *params;
+}
