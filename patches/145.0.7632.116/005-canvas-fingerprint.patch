@@ -207,6 +213,21 @@ CanvasAsyncBlobCreator::CanvasAsyncBlobCreator(
                            std::min(info.height(), max_dimension));
         src_data_.reset(info, src_data_.addr(), src_data_.rowBytes());
       }
+
+      // Aspect: apply canvas noise to toBlob/convertToBlob pixel data.
+      // peekPixels returns a read-only pointer, so we make a writable copy.
+      uint64_t noise_seed = GetCanvasNoiseSeed();
+      if (noise_seed != 0) {
+        size_t sz = src_data_.computeByteSize();
+        noised_storage_ = SkData::MakeUninitialized(sz);
+        memcpy(noised_storage_->writable_data(), src_data_.addr(), sz);
+        SkPixmap mutable_pm(src_data_.info(),
+                            noised_storage_->writable_data(),
+                            src_data_.rowBytes());
+        ApplyCanvasNoise(noise_seed, mutable_pm);
+        src_data_ = SkPixmap(src_data_.info(), noised_storage_->data(),
+                             src_data_.rowBytes());
+      }
     }
   }
 
