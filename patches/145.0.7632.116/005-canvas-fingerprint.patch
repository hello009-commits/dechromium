diff --git a/third_party/blink/renderer/platform/graphics/aspect_canvas_noise.cc b/third_party/blink/renderer/platform/graphics/aspect_canvas_noise.cc
new file mode 100644
index 0000000000000..2a4a0282131a2
--- /dev/null
+++ b/third_party/blink/renderer/platform/graphics/aspect_canvas_noise.cc
@@ -0,0 +1,172 @@
+#ifdef UNSAFE_BUFFERS_BUILD
+// Aspect: pixel noise function uses raw pointer arithmetic for performance.
+#pragma allow_unsafe_buffers
+#endif
+
+#include "third_party/blink/renderer/platform/graphics/aspect_canvas_noise.h"
+
+#include <algorithm>
+#include <cstring>
+
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "third_party/blink/public/common/switches.h"
+#include "third_party/skia/include/core/SkColorType.h"
+
+namespace blink {
+
+namespace {
+
+// Splitmix64-style hash for quality mixing.
+struct NoiseHash {
+  uint64_t state;
+
+  void Mix(uint64_t v) {
+    state += v * 0x9e3779b97f4a7c15ULL;
+    state = (state ^ (state >> 30)) * 0xbf58476d1ce4e5b9ULL;
+    state = (state ^ (state >> 27)) * 0x94d049bb133111ebULL;
+    state ^= (state >> 31);
+  }
+
+  int ValueBelow(int max_exclusive) {
+    if (max_exclusive <= 1)
+      return 0;
+    Mix(0x517cc1b727220a95ULL);
+    return static_cast<int>(state % static_cast<uint64_t>(max_exclusive));
+  }
+};
+
+// Determine R/G/B/A byte offsets from SkColorType.
+// Returns false if the color type is not 4-bytes-per-pixel.
+bool GetChannelOffsets(SkColorType ct,
+                       int& r_off,
+                       int& g_off,
+                       int& b_off,
+                       int& a_off) {
+  switch (ct) {
+    case kRGBA_8888_SkColorType:
+      r_off = 0; g_off = 1; b_off = 2; a_off = 3;
+      return true;
+    case kBGRA_8888_SkColorType:
+      r_off = 2; g_off = 1; b_off = 0; a_off = 3;
+      return true;
+    default:
+      return false;
+  }
+}
+
+void ApplyNoiseImpl(uint64_t seed,
+                    uint8_t* pixels,
+                    int width,
+                    int height,
+                    size_t row_bytes,
+                    int r_off,
+                    int g_off,
+                    int b_off,
+                    int a_off) {
+  if (seed == 0 || width <= 0 || height <= 0)
+    return;
+
+  constexpr int kBpp = 4;
+
+  for (int y = 0; y < height; ++y) {
+    uint8_t* row = pixels + y * row_bytes;
+
+    for (int x = 0; x < width; ++x) {
+      uint8_t* px = row + x * kBpp;
+
+      // Skip fully transparent pixels.
+      if (px[a_off] == 0)
+        continue;
+
+      // Read semantic channel values for hashing.
+      uint8_t sr = px[r_off];
+      uint8_t sg = px[g_off];
+      uint8_t sb = px[b_off];
+
+      // Build deterministic hash from semantic values + position + seed.
+      NoiseHash h{seed};
+      h.Mix(static_cast<uint64_t>(x) | (static_cast<uint64_t>(y) << 20));
+      h.Mix(static_cast<uint64_t>(sr) | (static_cast<uint64_t>(sg) << 8) |
+            (static_cast<uint64_t>(sb) << 16));
+
+      // Edge detection: check if left or above neighbor differs significantly.
+      bool is_edge = false;
+      if (x > 0) {
+        uint8_t* left = row + (x - 1) * kBpp;
+        int dr = std::abs(static_cast<int>(sr) - left[r_off]);
+        int dg = std::abs(static_cast<int>(sg) - left[g_off]);
+        int db = std::abs(static_cast<int>(sb) - left[b_off]);
+        if (dr > 4 || dg > 4 || db > 4)
+          is_edge = true;
+      }
+      if (!is_edge && y > 0) {
+        uint8_t* above = pixels + (y - 1) * row_bytes + x * kBpp;
+        int dr = std::abs(static_cast<int>(sr) - above[r_off]);
+        int dg = std::abs(static_cast<int>(sg) - above[g_off]);
+        int db = std::abs(static_cast<int>(sb) - above[b_off]);
+        if (dr > 4 || dg > 4 || db > 4)
+          is_edge = true;
+      }
+
+      int max_noise = is_edge ? 2 : 1;
+
+      // Only modify ~15% of flat pixels (deterministic via hash).
+      if (!is_edge) {
+        if (h.ValueBelow(100) >= 15)
+          continue;
+      }
+
+      // Apply noise to R, G, B only — never modify alpha.
+      int offsets[3] = {r_off, g_off, b_off};
+      for (int ch : offsets) {
+        int v = px[ch];
+        int mn = std::max(0, v - max_noise);
+        int mx = std::min(255, v + max_noise);
+        int range = mx - mn + 1;
+        px[ch] = static_cast<uint8_t>(mn + h.ValueBelow(range));
+      }
+    }
+  }
+}
+
+}  // namespace
+
+uint64_t GetCanvasNoiseSeed() {
+  static const uint64_t seed = []() -> uint64_t {
+    uint64_t s = 0;
+    const auto& cmd = *base::CommandLine::ForCurrentProcess();
+    if (cmd.HasSwitch(blink::switches::kAspectCanvasNoiseSeed))
+      base::StringToUint64(
+          cmd.GetSwitchValueASCII(blink::switches::kAspectCanvasNoiseSeed), &s);
+    return s;
+  }();
+  return seed;
+}
+
+void ApplyCanvasNoise(uint64_t seed, SkPixmap& pixmap) {
+  if (seed == 0 || pixmap.width() <= 0 || pixmap.height() <= 0)
+    return;
+
+  int r_off, g_off, b_off, a_off;
+  if (!GetChannelOffsets(pixmap.colorType(), r_off, g_off, b_off, a_off))
+    return;
+
+  ApplyNoiseImpl(seed,
+                 static_cast<uint8_t*>(pixmap.writable_addr()),
+                 pixmap.width(), pixmap.height(), pixmap.rowBytes(),
+                 r_off, g_off, b_off, a_off);
+}
+
+void ApplyCanvasNoiseRGBA(uint64_t seed,
+                          uint8_t* pixels,
+                          int width,
+                          int height) {
+  if (seed == 0 || !pixels || width <= 0 || height <= 0)
+    return;
+  ApplyNoiseImpl(seed, pixels, width, height,
+                 static_cast<size_t>(width) * 4,
+                 /*r_off=*/0, /*g_off=*/1, /*b_off=*/2, /*a_off=*/3);
+}
+
+}  // namespace blink
diff --git a/third_party/blink/renderer/platform/graphics/aspect_canvas_noise.h b/third_party/blink/renderer/platform/graphics/aspect_canvas_noise.h
new file mode 100644
index 0000000000000..b0bc68b51767b
--- /dev/null
+++ b/third_party/blink/renderer/platform/graphics/aspect_canvas_noise.h
@@ -0,0 +1,30 @@
+// Aspect: shared canvas noise function — channel-order-independent.
+#ifndef THIRD_PARTY_BLINK_RENDERER_PLATFORM_GRAPHICS_ASPECT_CANVAS_NOISE_H_
+#define THIRD_PARTY_BLINK_RENDERER_PLATFORM_GRAPHICS_ASPECT_CANVAS_NOISE_H_
+
+#include <cstdint>
+
+#include "third_party/blink/renderer/platform/platform_export.h"
+#include "third_party/skia/include/core/SkPixmap.h"
+
+namespace blink {
+
+// Apply deterministic noise to pixel data in a SkPixmap.
+// Reads pixmap.colorType() to determine R/G/B/A byte offsets, so the same
+// seed + pixel content produces identical noise regardless of RGBA vs BGRA
+// memory layout. Never modifies the alpha channel. Skips fully transparent
+// pixels.
+PLATFORM_EXPORT void ApplyCanvasNoise(uint64_t seed, SkPixmap& pixmap);
+
+// Convenience overload for raw RGBA_8888 buffers (always R=0,G=1,B=2,A=3).
+PLATFORM_EXPORT void ApplyCanvasNoiseRGBA(uint64_t seed,
+                                          uint8_t* pixels,
+                                          int width,
+                                          int height);
+
+// Read the canvas noise seed from the command line. Returns 0 if not set.
+PLATFORM_EXPORT uint64_t GetCanvasNoiseSeed();
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_PLATFORM_GRAPHICS_ASPECT_CANVAS_NOISE_H_
