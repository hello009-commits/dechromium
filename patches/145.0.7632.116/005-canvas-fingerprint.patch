+++ b/third_party/blink/renderer/modules/canvas/offscreencanvas2d/offscreen_canvas_rendering_context_2d.cc
@@ -27,6 +27,9 @@
 #include "third_party/blink/renderer/platform/graphics/canvas_resource.h"
 #include "third_party/blink/renderer/platform/graphics/canvas_resource_provider.h"
 #include "third_party/blink/renderer/platform/graphics/gpu/shared_gpu_context.h"
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "third_party/blink/public/common/switches.h"
 #include "third_party/blink/renderer/platform/graphics/paint/paint_canvas.h"
 #include "third_party/blink/renderer/platform/graphics/skia/skia_utils.h"
 #include "third_party/blink/renderer/platform/graphics/static_bitmap_image.h"
@@ -394,7 +397,27 @@ OffscreenCanvasRenderingContext2D::GetOrCreatePaintCanvas() {
       [[unlikely]] {
     return nullptr;
   }
-  return GetPaintCanvas();
+  MemoryManagedPaintCanvas* canvas = const_cast<MemoryManagedPaintCanvas*>(
+      static_cast<const OffscreenCanvasRenderingContext2D*>(this)
+          ->GetPaintCanvas());
+  if (canvas && !aspect_subpixel_applied_) {
+    static const uint64_t seed = []() -> uint64_t {
+      uint64_t s = 0;
+      const auto& cmd = *base::CommandLine::ForCurrentProcess();
+      if (cmd.HasSwitch(blink::switches::kAspectCanvasNoiseSeed))
+        base::StringToUint64(
+            cmd.GetSwitchValueASCII(blink::switches::kAspectCanvasNoiseSeed),
+            &s);
+      return s;
+    }();
+    if (seed != 0) {
+      double dx = static_cast<double>(seed & 0xFF) / 512.0;
+      double dy = static_cast<double>((seed >> 8) & 0xFF) / 512.0;
+      canvas->translate(static_cast<float>(dx), static_cast<float>(dy));
+    }
+    aspect_subpixel_applied_ = true;
+  }
+  return canvas;
 }
 
