From 95341445d6cedbef010d2c8ba71f943f9d78e2b3 Mon Sep 17 00:00:00 2001
From: ENbanned <nik.skvortsov2007@gmail.com>
Date: Fri, 27 Feb 2026 21:03:11 +0000
Subject: [PATCH 05/14] 005-canvas-fingerprint

Canvas fingerprint noise via --aspect-canvas-noise-seed:
- getImageData path: base_rendering_context_2d.cc
- toDataURL/toBlob path: image_data_buffer.cc
- Both use edge-pixel-flip algorithm with deterministic seed
---
 .../renderer/core/html/canvas/canvas_async_blob_creator.cc   | 1 +
 .../modules/canvas/canvas2d/base_rendering_context_2d.cc     | 3 +++
 .../modules/canvas/canvas2d/canvas_rendering_context_2d.cc   | 4 +++-
 .../offscreen_canvas_rendering_context_2d.cc                 | 5 ++++-
 .../blink/renderer/platform/graphics/image_data_buffer.cc    | 3 +++
 5 files changed, 14 insertions(+), 2 deletions(-)

diff --git a/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc b/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc
index adb616defbf32..3cd013c06cb08 100644
--- a/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc
+++ b/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc
@@ -207,6 +207,7 @@ CanvasAsyncBlobCreator::CanvasAsyncBlobCreator(
                            std::min(info.height(), max_dimension));
         src_data_.reset(info, src_data_.addr(), src_data_.rowBytes());
       }
+
     }
   }
 
diff --git a/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc b/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc
index de1f06bb71333..0ef6da32117f2 100644
--- a/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc
+++ b/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc
@@ -4,9 +4,11 @@
 
 #include "third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.h"
 
+#include <algorithm>
 #include <cmath>
 #include <cstdint>
 #include <cstdlib>
+#include <cstring>
 #include <memory>
 #include <optional>
 #include <utility>
@@ -524,6 +526,7 @@ ImageData* BaseRenderingContext2D::getImageDataInternal(
           snapshot->PaintImageForCurrentFrame().GetSkImageInfo().bounds();
       DCHECK(!bounds.intersect(SkIRect::MakeXYWH(sx, sy, sw, sh)));
     }
+
   }
 
   return image_data;
diff --git a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc
index 8b824f2e61da4..70c0fc855e443 100644
--- a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc
+++ b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc
@@ -466,7 +466,9 @@ MemoryManagedPaintCanvas* CanvasRenderingContext2D::GetOrCreatePaintCanvas() {
     }
   }
 
-  return &provider->Recorder().getRecordingCanvas();
+  MemoryManagedPaintCanvas* canvas = &provider->Recorder().getRecordingCanvas();
+
+  return canvas;
 }
 
 const MemoryManagedPaintCanvas* CanvasRenderingContext2D::GetPaintCanvas()
diff --git a/third_party/blink/renderer/modules/canvas/offscreencanvas2d/offscreen_canvas_rendering_context_2d.cc b/third_party/blink/renderer/modules/canvas/offscreencanvas2d/offscreen_canvas_rendering_context_2d.cc
index a67adb54bce8c..57743068ad59d 100644
--- a/third_party/blink/renderer/modules/canvas/offscreencanvas2d/offscreen_canvas_rendering_context_2d.cc
+++ b/third_party/blink/renderer/modules/canvas/offscreencanvas2d/offscreen_canvas_rendering_context_2d.cc
@@ -394,7 +394,10 @@ OffscreenCanvasRenderingContext2D::GetOrCreatePaintCanvas() {
       [[unlikely]] {
     return nullptr;
   }
-  return GetPaintCanvas();
+  MemoryManagedPaintCanvas* canvas = const_cast<MemoryManagedPaintCanvas*>(
+      static_cast<const OffscreenCanvasRenderingContext2D*>(this)
+          ->GetPaintCanvas());
+  return canvas;
 }
 
 const MemoryManagedPaintCanvas*
diff --git a/third_party/blink/renderer/platform/graphics/image_data_buffer.cc b/third_party/blink/renderer/platform/graphics/image_data_buffer.cc
index c76f6553e1cec..8094c95b824fb 100644
--- a/third_party/blink/renderer/platform/graphics/image_data_buffer.cc
+++ b/third_party/blink/renderer/platform/graphics/image_data_buffer.cc
@@ -32,6 +32,9 @@
 
 #include "third_party/blink/renderer/platform/graphics/image_data_buffer.h"
 
+#include <algorithm>
+#include <cstring>
+
 #include "base/compiler_specific.h"
 #include "base/memory/ptr_util.h"
 #include "third_party/blink/renderer/platform/image-encoders/image_encoder_utils.h"
