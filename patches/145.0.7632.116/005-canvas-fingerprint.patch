Subject: [PATCH 05/13] 005-canvas-fingerprint

Canvas fingerprint noise via --aspect-canvas-noise-seed:
- getImageData path: base_rendering_context_2d.cc
- toDataURL/toBlob path: image_data_buffer.cc
- Both use edge-pixel-flip algorithm with deterministic seed
---
 .../html/canvas/canvas_async_blob_creator.cc  |  1 +
 .../canvas2d/base_rendering_context_2d.cc     |  3 ++
 .../canvas2d/canvas_rendering_context_2d.cc   | 28 ++++++++++++++++++-
 .../canvas2d/canvas_rendering_context_2d.h    |  1 +
 .../offscreen_canvas_rendering_context_2d.cc  | 25 ++++++++++++++++-
 .../offscreen_canvas_rendering_context_2d.h   |  1 +
 .../platform/graphics/image_data_buffer.cc    |  3 ++
 7 files changed, 60 insertions(+), 2 deletions(-)

diff --git a/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc b/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc
index adb616defbf32..3cd013c06cb08 100644
--- a/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc
+++ b/third_party/blink/renderer/core/html/canvas/canvas_async_blob_creator.cc
@@ -207,6 +207,7 @@ CanvasAsyncBlobCreator::CanvasAsyncBlobCreator(
                            std::min(info.height(), max_dimension));
         src_data_.reset(info, src_data_.addr(), src_data_.rowBytes());
       }
+
     }
   }
 
diff --git a/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc b/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc
index de1f06bb71333..0ef6da32117f2 100644
--- a/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc
+++ b/third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.cc
@@ -4,9 +4,11 @@
 
 #include "third_party/blink/renderer/modules/canvas/canvas2d/base_rendering_context_2d.h"
 
+#include <algorithm>
 #include <cmath>
 #include <cstdint>
 #include <cstdlib>
+#include <cstring>
 #include <memory>
 #include <optional>
 #include <utility>
@@ -524,6 +526,7 @@ ImageData* BaseRenderingContext2D::getImageDataInternal(
           snapshot->PaintImageForCurrentFrame().GetSkImageInfo().bounds();
       DCHECK(!bounds.intersect(SkIRect::MakeXYWH(sx, sy, sw, sh)));
     }
+
   }
 
   return image_data;
diff --git a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc
index 8b824f2e61da4..e74b0db31bf49 100644
--- a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc
+++ b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_rendering_context_2d.cc
@@ -42,7 +42,10 @@
 
 #include "base/check.h"
 #include "base/check_op.h"
+#include "base/command_line.h"
 #include "base/feature_list.h"
+#include "base/strings/string_number_conversions.h"
+#include "third_party/blink/public/common/switches.h"
 #include "base/location.h"
 #include "base/memory/scoped_refptr.h"
 #include "base/memory/values_equivalent.h"
@@ -466,7 +469,30 @@ MemoryManagedPaintCanvas* CanvasRenderingContext2D::GetOrCreatePaintCanvas() {
     }
   }
 
-  return &provider->Recorder().getRecordingCanvas();
+  MemoryManagedPaintCanvas* canvas = &provider->Recorder().getRecordingCanvas();
+
+  // Aspect: apply seed-dependent sub-pixel offset to the rendering origin.
+  // This shifts all drawing by a fraction of a pixel, producing unique
+  // anti-aliased edges per profile without any post-readback modification.
+  if (!aspect_subpixel_applied_) {
+    static const uint64_t seed = []() -> uint64_t {
+      uint64_t s = 0;
+      const auto& cmd = *base::CommandLine::ForCurrentProcess();
+      if (cmd.HasSwitch(blink::switches::kAspectCanvasNoiseSeed))
+        base::StringToUint64(
+            cmd.GetSwitchValueASCII(blink::switches::kAspectCanvasNoiseSeed),
+            &s);
+      return s;
+    }();
+    if (seed != 0) {
+      double dx = static_cast<double>(seed & 0xFF) / 512.0;
+      double dy = static_cast<double>((seed >> 8) & 0xFF) / 512.0;
+      canvas->translate(static_cast<float>(dx), static_cast<float>(dy));
+    }
+    aspect_subpixel_applied_ = true;
+  }
+
+  return canvas;
 }
 
 const MemoryManagedPaintCanvas* CanvasRenderingContext2D::GetPaintCanvas()
